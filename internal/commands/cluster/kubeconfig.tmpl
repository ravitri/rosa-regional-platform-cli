apiVersion: v1
kind: Config
clusters:
  - cluster:
      server: {{.Server}}
    name: {{.ClusterName}}
users:
  - name: {{.ClusterName}}-iam
    user:
      exec:
        apiVersion: client.authentication.k8s.io/v1
        interactiveMode: Never
        command: {{.RosactlPath}}
        args:
          - cluster
          - get-token
          - --cluster-id
          - {{.ClusterID}}
          - --region
          - {{.Region}}
contexts:
  - context:
      cluster: {{.ClusterName}}
      user: {{.ClusterName}}-iam
    name: {{.ClusterName}}
current-context: {{.ClusterName}}
